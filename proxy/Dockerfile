FROM mitmproxy/mitmproxy:11

RUN pip install --no-cache-dir pyyaml

WORKDIR /app
COPY policy.yaml /app/policy.yaml
COPY addons/gatekeeper.py /app/addons/gatekeeper.py
COPY addons/flowlog.py /app/addons/flowlog.py
COPY entrypoint.sh /app/entrypoint.sh

# CA is generated by mitmproxy on first run and persisted via volume.
# Entrypoint: mitmweb (UI on 8081, password via MITMWEB_PASSWORD) + proxy on 8080
ENTRYPOINT ["/app/entrypoint.sh"]
