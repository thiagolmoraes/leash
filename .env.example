# Copy to .env and fill in real keys before running `make up`
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
XAI_API_KEY=xai-...

# Password for the mitmweb UI on :8081 (exposes all decrypted flows).
# Leave blank to run the UI without auth (not recommended).
MITMWEB_PASSWORD=

# Optional: LLM-assisted semantic scanning for the Skills tab (SkillSpector).
# v1 runs static-only (--no-llm) by default — these are unused unless you
# wire up LLM scanning later. Reuses ANTHROPIC_API_KEY/OPENAI_API_KEY above.
SKILLSPECTOR_PROVIDER=
OPENAI_BASE_URL=
